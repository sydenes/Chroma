{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=chroma_crm;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "Chroma",
    "Audience": "Chroma.Api",
    "SecretKey": "CHANGE_ME_USE_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Storage": {
    "Provider": "Local",
    "LocalPath": "storage",
    "MaxFileSizeMb": 25
  },
  "Integrations": {
    "ChannelSecretKey": "CHANGE_ME_32_CHAR_ENCRYPTION_KEY!!",
    "WhatsApp": {
      "ApiVersion": "v18.0"
    },
    "Meta": {
      "ApiVersion": "v18.0"
    },
    "Email": {
      "SmtpHost": "localhost",
      "SmtpPort": 587
    },
    "Telegram": {
      "ApiBaseUrl": "https://api.telegram.org"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
